# Deployment Tracking (Local Git Hooks Only)
# Copy this file to .env.local and fill in the values

# Unique identifier for this website (generate a UUID)
PVS_WEBSITE_ID=your-uuid-here

# PVS API endpoint for deployment tracking
PVS_API_URL=https://pvs-server-62hx7.ondigitalocean.app

# Production URL of this website
PVS_BASE_URL=https://ifferspictures.com

# Contact Form API (server-side only)
PVS_CONTACT_API_URL=https://api.pixelversestudios.io
PVS_WEBSITE_SLUG=iffers-pictures

# Google Analytics 4 (client-side)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Managed media catalog and admin proxy
# PVS_API_URL is also used by /api/media/* and /api/media-admin/* proxy routes.
MEDIA_PUBLIC_BASE_URL=https://media.ifferspictures.com
# MEDIA_PUBLIC_BASE_URLS=https://pub-537ca6ef78984d5e9c262aa7ef7afdf0.r2.dev,https://media.ifferspictures.com

# Optional shared bearer secret for /api/media/revalidate.
# Must match the Pixelverse server MEDIA_REVALIDATION_SECRET when configured.
MEDIA_REVALIDATION_SECRET=
